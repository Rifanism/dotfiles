# --- KONTROL AUDIO (Volume) ---

# Naikkan volume 5% (Tombol Fn Volume Up / Super + F12)
{XF86AudioRaiseVolume}
    pamixer -i 5

# Turunkan volume 5% (Tombol Fn Volume Down / Super + F11)
{XF86AudioLowerVolume}
    pamixer -d 5

# Mute/Unmute audio (Tombol Fn Mute / Super + F10)
{XF86AudioMute}
    pamixer -t

# --- KONTROL KECERAHAN LAYAR (Brightness) ---

# Naikkan kecerahan 5% (Tombol Fn Brightness Up / Super + F6)
{XF86MonBrightnessUp}
    brightnessctl set +5%

# Turunkan kecerahan 5% (Tombol Fn Brightness Down / Super + F5)
{XF86MonBrightnessDown}
    brightnessctl set 5%-

# --- FITUR SCREENSHOT (maim) ---

# Screenshot Fullscreen (Tombol PrintScreen)
Print
    maim ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png && xclip -selection clipboard -t image/png -i $(ls -1t ~/Pictures/Screenshots/*.png | head -n 1) && notify-send "Screenshot" "Image saved successfully!"

# Screenshot Crop / Pilih Area (Tombol Super + PrintScreen)
super + Print
    maim -s ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png && xclip -selection clipboard -t image/png -i $(ls -1t ~/Pictures/Screenshots/*.png | head -n 1) && notify-send "Screenshot" "Image saved successfully!"

